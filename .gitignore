# Local Python environments and secrets
.venv/
.env
.env.*
!.env.example

# Generated Python and test files
__pycache__/
.pytest_cache/
*.py[cod]
*.egg-info/
build/
dist/

# Operating-system and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/

# Local Inspect runs. Accepted historical pilot logs are preserved separately
# under provenance/original-v0.1/.
/logs/
/outputs/
/tmp-logs/
.inspect-trace.log*

# LaTeX build by-products. The named working draft remains tracked.
/paper/*.aux
/paper/*.bbl
/paper/*.blg
/paper/*.fdb_latexmk
/paper/*.fls
/paper/*.log
/paper/*.out
/paper/*.synctex.gz
/paper/main.pdf
/paper/tmp/
